PORT=8080

# Supabase Connection (Pilih salah satu: DATABASE_URL atau individual params)
# Cara termudah: Ambil dari Project Settings > Database > Connection String > URI
DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres

# Atau gunakan individual params:
DB_HOST=db.[YOUR-REF].supabase.co
DB_USER=postgres
DB_PASSWORD=[YOUR-PASSWORD]
DB_NAME=postgres
DB_PORT=5432
DB_SSLMODE=require

# Security Keys
APP_CLIENT_KEY=ganti_dengan_key_rahasia_mobile_anda
ADMIN_SECRET_KEY=ganti_dengan_key_rahasia_admin_anda

# CORS - Untuk production, isi domain yang diizinkan (comma-separated)
# Contoh: https://posify.example.com,https://www.posify.example.com
# Kosongkan untuk mengizinkan semua origin (development)
ALLOWED_ORIGINS=
