            "item": [
                {
                    "name": "Activate License",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "X-App-Client-Key", "value": "{{app_client_key}}", "type": "text" },
                            { "key": "Content-Type", "value": "application/json", "type": "text" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"license_code\": \"VALID-LICENSE-CODE\",\n    \"device_fingerprint\": \"device-unique-id-123\",\n    \"device_model\": \"Samsung S24\",\n    \"os_version\": \"Android 14\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/license/activate",
